# riiskit standard .gitignore

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/
env/

# Node
node_modules/
.npm/

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/settings.json
.idea/
*.suo
*.user

# Secrets / local config
.env
.env.*
*.key
*.pem
secrets/
local/

# Logs
*.log
logs/

# Build artifacts
*.o
*.obj
*.dll
*.exe
